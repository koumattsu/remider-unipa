# アプリケーション基本設定
APP_NAME=UniPA Reminder App
APP_VERSION=1.0.0
DEBUG=True
ENV=development

# データベース設定
DATABASE_URL=sqlite:///./unipa_reminder.db

# フロントエンドURL
FRONTEND_URL=http://localhost:5173

# CORS設定（カンマ区切り）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# セッション / セキュリティ
SESSION_SECRET=replace-me-in-production
SESSION_MAX_AGE_SECONDS=2592000
FEATURE_HASH_SECRET=replace-me-in-production
SESSION_COOKIE_SAMESITE_OVERRIDE=

# ビルド識別
BUILD_SHA=
RENDER_GIT_COMMIT=

# LINE Messaging API設定（将来用）
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# LINE Login
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=
LINE_LOGIN_REDIRECT_URI=http://localhost:8000/api/v1/auth/line/callback

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ダミー認証設定（開発用）
DUMMY_AUTH_ENABLED=True
DUMMY_USER_ID=1

# DB初期化（必要時のみ）
AUTO_INIT_DB=False