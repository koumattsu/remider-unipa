# アプリケーション基本設定
APP_NAME=UniPA Reminder App
APP_VERSION=1.0.0
DEBUG=True

# データベース設定
# SQLite（開発時）
DATABASE_URL=sqlite:///./unipa_reminder.db

# PostgreSQL（将来移行時）
# DATABASE_URL=postgresql://user:password@localhost:5432/unipa_reminder

# CORS設定（カンマ区切り）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# LINE Messaging API設定（将来用）
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ダミー認証設定（開発用）
DUMMY_AUTH_ENABLED=True
DUMMY_USER_ID=1

